# Database
DATABASE_URL=postgresql+asyncpg://trading:changeme@localhost:5432/trading
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379/0

# API
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
CORS_ORIGINS=http://localhost:3000
AUTH_REQUIRED=false

# Telegram (live phase)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Optional: socks5://127.0.0.1:1080 or http://127.0.0.1:7890
TELEGRAM_PROXY_URL=

# Exchange (live phase)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# App
CONFIG_DIR=../config
ENVIRONMENT=development

# Frontend (browser must reach API on the host; use localhost, not docker service names)
NEXT_PUBLIC_API_URL=http://localhost:8000
